white;\n    border: none;\n    padding: 0.9rem 1.25rem;\n    border-radius: 999px;\n    font-size: 1rem;\n    cursor: pointer;\n    transition: background 0.2s ease;\n  }\n\n  &--primary:disabled {\n    opacity: 0.65;\n    cursor: not-allowed;\n  }\n}\n\n.error-message {\n  margin-top: 1rem;\n  color: #c62828;\n}\n</style>\n"],"version":3}